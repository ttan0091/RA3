# Environment Configuration for MaliciousAgentSkillsBench
# Copy this file to .env and fill in your values

# GitHub Token (for downloading skill repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key (for Claude Code analysis)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Custom API base URL
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: SkillsMP API Key
# SKILLSMP_API_KEY=

# Optional: Skip crawl phase (true/false)
# SKIP_CRAWL=false

# Optional: Override concurrent worker count
# MAX_WORKERS=10

# Optional: NOVA Mode for Docker builds (none/lite/full)
# NOVA_MODE=none
